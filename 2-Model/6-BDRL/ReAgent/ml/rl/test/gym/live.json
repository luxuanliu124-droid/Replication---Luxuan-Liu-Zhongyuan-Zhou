{
  "env": "live",
  "model_type":"discrete",
  "max_replay_memory_size": 100000,
  "use_gpu": true,
  "rl": {
    "gamma": 0.99,
    "target_update_rate": 0.1,
    "maxq_learning": true,
    "epsilon": 0.05,
    "temperature": 0.35,
    "softmax_policy": 0
  },
  "rainbow": {
    "double_q_learning": true,
    "dueling_architecture": false
  },
  "training": {
    "layers": [-1, 32, 32, -1],
    "activations": ["relu", "relu", "linear"],
    "minibatch_size": 256,
    "learning_rate": 0.01,
    "optimizer": "ADAM",
    "lr_decay": 0.99
  },
  "run_details": {
    "num_episodes": 200,
    "max_steps": 25,
    "train_every_ts": 3,
    "train_after_ts": 1,
    "test_every_ts": 500,
    "test_after_ts": 1000,
    "num_train_batches": 1,
    "avg_over_num_episodes": 25,
    "offline_train_epochs": 10
  }
}
